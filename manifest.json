{
    "manifest_version": 3,
    "name": "Cache Cleaning",
    "version": 1.0,
    "permissions": ["browsingData", "activeTab"],
    "action":{
        "default_popup": "popup.html",
        "default_icon":{
            "16": "icon16.png",
            "48": "icon48.png"
        } 
    },
    "icons":{
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }

}